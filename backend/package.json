{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/db/migrations && cp src/db/schema.sql src/db/seed.sql dist/db/ && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.87",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "better-sqlite3": "^12.10.0",
    "csv-parse": "^7.0.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.3.3",
    "shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
