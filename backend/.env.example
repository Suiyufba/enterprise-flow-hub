# ── AI Provider ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Agent Runtime ──
# Runtime mode: "hermes" or "legacy"
AGENT_RUNTIME=legacy
# Fallback runtime when Hermes is unavailable (default: legacy)
AGENT_FALLBACK_RUNTIME=legacy

# ── Hermes-Agent ──
# Hermes API server URL (Docker internal)
HERMES_API_URL=http://hermes-agent:8642
# Shared API key between backend and Hermes
HERMES_API_KEY=
# Model name for Hermes
HERMES_MODEL=hermes-agent
# Comma-separated user IDs for gradual rollout (empty = all users)
HERMES_ENABLED_USER_IDS=

# ── Internal API ──
# Key for Hermes tool bridge (must match between backend and Hermes)
INTERNAL_API_KEY=
