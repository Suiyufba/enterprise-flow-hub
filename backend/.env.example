# ── AI Provider ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Agent Runtime ──
# Runtime mode: "claude-code" or "legacy"
AGENT_RUNTIME=claude-code
# Manual fallback runtime
AGENT_FALLBACK_RUNTIME=legacy

# Optional custom free-code/Claude Code executable. The SDK-bundled executable
# is used when omitted.
CLAUDE_CODE_EXECUTABLE=
CLAUDE_CODE_WORKDIR=/data/claude-workdir

# ── Feishu Official MCP ──
# Create a self-built app in Feishu Open Platform. Keep these values out of git.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional. Required for APIs that must act as a specific user or read private resources.
FEISHU_USER_ACCESS_TOKEN=
FEISHU_DOMAIN=https://open.feishu.cn
