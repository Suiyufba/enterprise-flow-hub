# ── AI Provider ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Agent Runtime ──
# Runtime mode: "claude-code" or "legacy"
AGENT_RUNTIME=claude-code
# Manual fallback runtime
AGENT_FALLBACK_RUNTIME=legacy

# Optional custom free-code/Claude Code executable. The SDK-bundled executable
# is used when omitted.
CLAUDE_CODE_EXECUTABLE=
CLAUDE_CODE_WORKDIR=/data/claude-workdir
